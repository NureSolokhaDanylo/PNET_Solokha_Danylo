@implements IDisposable
@inject NavigationManager NavigationManager

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid px-0">
        <a class="navbar-brand" href="">PharmaStock</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">

        <div class="nav-section-label">Catalog</div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="categories">
                <span class="bi bi-tags-fill" aria-hidden="true"></span> Categories
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="suppliers">
                <span class="bi bi-truck" aria-hidden="true"></span> Suppliers
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="medicines">
                <span class="bi bi-capsule" aria-hidden="true"></span> Medicines
            </NavLink>
        </div>

        <div class="nav-section-label">Operations</div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="inventory">
                <span class="bi bi-box-seam" aria-hidden="true"></span> Inventory
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="sales">
                <span class="bi bi-cart-fill" aria-hidden="true"></span> Sales
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="sales-archive">
                <span class="bi bi-archive" aria-hidden="true"></span> Sales Archive
            </NavLink>
        </div>

        <div class="nav-section-label">System</div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="system-audit">
                <span class="bi bi-shield-lock" aria-hidden="true"></span> System Audit
            </NavLink>
        </div>

    </nav>
</div>

@code {
    private string? currentUrl;

    protected override void OnInitialized()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        StateHasChanged();
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
