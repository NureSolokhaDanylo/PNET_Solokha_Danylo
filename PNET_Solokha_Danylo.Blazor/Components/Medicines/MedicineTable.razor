@using PNET_Solokha_Danylo.Domain.Entities
@using PNET_Solokha_Danylo.Blazor.Components.Common

<div id="medicines-table-card" class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="card-body p-0">
        @if (IsLoading)
        {
            <div class="d-flex flex-column align-items-center justify-content-center py-5">
                <div class="spinner-border text-primary mb-3" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <span class="text-secondary">Fetching medicines...</span>
            </div>
        }
        else if (Medicines == null || !Medicines.Any())
        {
            <div class="text-center py-5">
                <div class="mb-3 text-muted">
                    <i class="bi bi-capsule display-3"></i>
                </div>
                <h5 class="fw-semibold text-dark">No medicines found</h5>
                <p class="text-muted px-4">There are no medicines registered matching your current filters.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Name</th>
                            <th>Category</th>
                            <th>Supplier</th>
                            <th class="text-end">Base Price</th>
                            <th class="text-end">Total Stock</th>
                            <th class="text-center" style="width: 120px;">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var medicine in Medicines)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex flex-column">
                                        <a href="/medicines/@medicine.MedicineId" class="fw-bold text-primary text-decoration-none">@medicine.Name</a>
                                        <span class="text-muted extra-small">ID: #@medicine.MedicineId</span>
                                    </div>
                                </td>
                                <td>
                                    @if (medicine.Category != null)
                                    {
                                        <a href="/categories/@medicine.CategoryId" class="badge bg-info-subtle text-info-emphasis px-2 py-1 fs-7 text-decoration-none">
                                            @medicine.Category.Name
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="badge bg-info-subtle text-info-emphasis px-2 py-1 fs-7">General</span>
                                    }
                                </td>
                                <td>
                                    @if (medicine.Supplier != null)
                                    {
                                        <a href="/suppliers/@medicine.SupplierId" class="text-primary small text-decoration-none"><i class="bi bi-building me-1"></i>@medicine.Supplier.Name</a>
                                    }
                                    else
                                    {
                                        <span class="text-secondary small"><i class="bi bi-building me-1"></i>Unknown</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <span class="fw-semibold text-dark">@medicine.BasePrice.ToString("C")</span>
                                </td>
                                <td class="text-end">
                                    <span class="badge bg-light text-dark font-monospace border px-2 py-1">@medicine.TotalStock</span>
                                </td>
                                <td class="text-center">
                                    @if (medicine.IsActive)
                                    {
                                        <span class="badge bg-success px-2 py-1 rounded-pill">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger px-2 py-1 rounded-pill">Inactive</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <PaginationControl TotalCount="TotalCount" Skip="Skip" PageSize="Take" OnPageChanged="OnPageChanged" />
        }
    </div>
</div>

@code {
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public List<Medicine>? Medicines { get; set; }
    [Parameter] public int TotalCount { get; set; }
    [Parameter] public int Skip { get; set; }
    [Parameter] public int Take { get; set; }
    [Parameter] public EventCallback<(int Skip, int Take)> OnPageChanged { get; set; }
}
