@using PNET_Solokha_Danylo.Blazor.Components.Categories
@using PNET_Solokha_Danylo.Blazor.Components.Suppliers

<div class="card border-0 shadow-sm mb-4 rounded-4 filter-card">
    <div class="card-body p-4">
        <h5 class="fw-semibold mb-3 d-flex align-items-center">
            <i class="bi bi-funnel-fill text-primary me-2"></i> Filters & Search
        </h5>
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label text-secondary small fw-medium">Search Keyword</label>
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" class="form-control border-start-0 ps-0" placeholder="e.g. Paracetamol, Ibuprofen..." value="@SearchTerm" @oninput="HandleSearchInput" @onkeyup="OnSearchKeyUp" />
                    @if (!string.IsNullOrEmpty(SearchTerm))
                    {
                        <button class="btn btn-outline-secondary" type="button" @onclick="ClearSearch">
                            <i class="bi bi-x-lg"></i>
                        </button>
                    }
                </div>
            </div>

            <div class="col-md-6">
                <label class="form-label text-secondary small fw-medium">Active Status</label>
                <select class="form-select rounded-3" value="@FilterIsActiveString" @onchange="HandleStatusChanged">
                    <option value="all">All Statuses</option>
                    <option value="active">Active Only</option>
                    <option value="inactive">Inactive Only</option>
                </select>
            </div>

            <div class="col-md-6">
                <label class="form-label text-secondary small fw-medium">Filter by Category</label>
                <CategorySelector Value="FilterCategoryId" ValueChanged="HandleFilterCategoryChanged" />
            </div>

            <div class="col-md-6">
                <label class="form-label text-secondary small fw-medium">Filter by Supplier</label>
                <SupplierSelector Value="FilterSupplierId" ValueChanged="HandleFilterSupplierChanged" />
            </div>

            <div class="col-12 d-flex justify-content-end gap-2 mt-2">
                <button class="btn btn-light rounded-3 px-4 text-secondary" @onclick="HandleReset">
                    <i class="bi bi-arrow-counterclockwise me-1"></i> Reset
                </button>
                <button class="btn btn-primary rounded-3 px-4" @onclick="HandleApply">
                    <i class="bi bi-search me-1"></i> Search Catalog
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public string? SearchTerm { get; set; }
    [Parameter] public EventCallback<string?> SearchTermChanged { get; set; }

    [Parameter] public string FilterIsActiveString { get; set; } = "all";
    [Parameter] public EventCallback<string> FilterIsActiveStringChanged { get; set; }

    [Parameter] public int? FilterCategoryId { get; set; }
    [Parameter] public EventCallback<int?> FilterCategoryIdChanged { get; set; }

    [Parameter] public int? FilterSupplierId { get; set; }
    [Parameter] public EventCallback<int?> FilterSupplierIdChanged { get; set; }

    [Parameter] public EventCallback OnFiltersApplied { get; set; }
    [Parameter] public EventCallback OnFiltersReset { get; set; }

    private async Task HandleSearchInput(ChangeEventArgs e)
    {
        SearchTerm = e.Value?.ToString();
        await SearchTermChanged.InvokeAsync(SearchTerm);
    }

    private async Task OnSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await OnFiltersApplied.InvokeAsync();
        }
    }

    private async Task ClearSearch()
    {
        SearchTerm = null;
        await SearchTermChanged.InvokeAsync(SearchTerm);
        await OnFiltersApplied.InvokeAsync();
    }

    private async Task HandleStatusChanged(ChangeEventArgs e)
    {
        FilterIsActiveString = e.Value?.ToString() ?? "all";
        await FilterIsActiveStringChanged.InvokeAsync(FilterIsActiveString);
    }

    private async Task HandleFilterCategoryChanged(int? newValue)
    {
        FilterCategoryId = newValue;
        await FilterCategoryIdChanged.InvokeAsync(FilterCategoryId);
    }

    private async Task HandleFilterSupplierChanged(int? newValue)
    {
        FilterSupplierId = newValue;
        await FilterSupplierIdChanged.InvokeAsync(FilterSupplierId);
    }

    private async Task HandleApply()
    {
        await OnFiltersApplied.InvokeAsync();
    }

    private async Task HandleReset()
    {
        SearchTerm = null;
        FilterIsActiveString = "all";
        FilterCategoryId = null;
        FilterSupplierId = null;
        
        await SearchTermChanged.InvokeAsync(SearchTerm);
        await FilterIsActiveStringChanged.InvokeAsync(FilterIsActiveString);
        await FilterCategoryIdChanged.InvokeAsync(FilterCategoryId);
        await FilterSupplierIdChanged.InvokeAsync(FilterSupplierId);
        
        await OnFiltersReset.InvokeAsync();
    }
}
