@page "/suppliers/{SupplierId:int}"
@rendermode InteractiveServer
@using PNET_Solokha_Danylo.Application.Suppliers.Queries.GetSupplierDetails
@using PNET_Solokha_Danylo.Application.Suppliers.Commands.DeleteSupplier
@inject IMediator Mediator
@inject NavigationManager NavigationManager
@inject ILogger<SupplierDetails> Logger

<PageTitle>Supplier Details - @(details?.Name ?? "Loading...")</PageTitle>

<div class="container-fluid py-4">
    <!-- Breadcrumb & Back Nav -->
    <div class="mb-4 d-flex align-items-center justify-content-between">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="suppliers" class="text-primary text-decoration-none">Suppliers</a></li>
                <li class="breadcrumb-item active" aria-current="page">Details</li>
            </ol>
        </nav>
        <div class="d-flex gap-2">
            @if (!isEditMode && !isDeleteConfirm && details != null)
            {
                <button class="btn btn-outline-primary btn-sm rounded-3" @onclick="EnterEditMode">
                    <i class="bi bi-pencil-fill me-1"></i> Edit
                </button>
                <button class="btn btn-outline-danger btn-sm rounded-3" @onclick="EnterDeleteConfirm">
                    <i class="bi bi-trash3-fill me-1"></i> Delete
                </button>
            }
            <a href="suppliers" class="btn btn-outline-secondary btn-sm rounded-3">
                <i class="bi bi-arrow-left me-1"></i> Back to List
            </a>
        </div>
    </div>

    <!-- Global action alerts -->
    @if (!string.IsNullOrEmpty(actionError))
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-4 shadow-sm mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @actionError
            <button type="button" class="btn-close" @onclick="() => actionError = null" aria-label="Close"></button>
        </div>
    }
    @if (showActionSuccess)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-4 shadow-sm mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> Supplier updated successfully!
            <button type="button" class="btn-close" @onclick="() => showActionSuccess = false" aria-label="Close"></button>
        </div>
    }

    <!-- Delete Confirmation Panel -->
    @if (isDeleteConfirm && details != null)
    {
        <div class="card border-0 shadow-sm rounded-4 mb-4 border-danger" style="border: 2px solid var(--bs-danger) !important;">
            <div class="card-body p-4">
                <div class="d-flex align-items-start gap-3">
                    <div class="bg-danger-subtle text-danger rounded-3 p-3 flex-shrink-0">
                        <i class="bi bi-exclamation-triangle-fill fs-4"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h5 class="fw-bold text-danger mb-1">Delete Supplier?</h5>
                        <p class="text-secondary mb-3">
                            You are about to permanently delete <strong>«@details.Name»</strong> (ID #@details.SupplierId).
                            This action cannot be undone.<br />
                            <span class="small text-muted">If there are medicines linked to this supplier, deletion will be blocked.</span>
                        </p>
                        <div class="d-flex gap-2">
                            <button class="btn btn-danger rounded-3 px-4" @onclick="ConfirmDelete" disabled="@isActionLoading">
                                @if (isActionLoading)
                                {
                                    <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                }
                                else
                                {
                                    <i class="bi bi-trash3-fill me-1"></i>
                                }
                                Confirm Delete
                            </button>
                            <button class="btn btn-outline-secondary rounded-3" @onclick="CancelAction" disabled="@isActionLoading">
                                <i class="bi bi-x-lg me-1"></i> Cancel
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Edit Form Panel -->
    @if (isEditMode && details != null)
    {
        <PNET_Solokha_Danylo.Blazor.Components.Suppliers.EditSupplierForm 
            SupplierId="SupplierId" 
            InitialName="@details.Name" 
            InitialCountry="@details.Country" 
            InitialNotes="@details.Notes" 
            OnSaved="HandleEditSuccess" 
            OnCancel="CancelAction" />
    }

    @if (isLoading)
    {
        <div class="d-flex flex-column align-items-center justify-content-center py-5">
            <div class="spinner-border text-primary mb-3" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <span class="text-secondary">Fetching supplier details...</span>
        </div>
    }
    else if (details == null)
    {
        <div class="alert alert-danger rounded-4 p-4 shadow-sm" role="alert">
            <div class="d-flex align-items-center">
                <i class="bi bi-exclamation-triangle-fill fs-2 me-3 text-danger"></i>
                <div>
                    <h5 class="alert-heading fw-bold mb-1">Supplier Not Found</h5>
                    <p class="mb-0">The requested supplier with ID #@SupplierId does not exist in the database.</p>
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- Header Section -->
        <div class="card border-0 shadow-sm rounded-4 mb-4 overflow-hidden header-card">
            <div class="card-body p-4 p-md-5 text-white">
                <div class="row align-items-center">
                    <div class="col-md-8">
                        <span class="badge bg-white bg-opacity-25 text-white px-3 py-2 rounded-pill fs-7 mb-3 font-monospace">Supplier #@details.SupplierId</span>
                        <h1 class="display-5 fw-bold mb-2 text-white">@details.Name</h1>
                        <p class="lead mb-0 text-white-50"><i class="bi bi-globe me-2 text-warning"></i>Country: <strong>@details.Country</strong></p>
                        @if (!string.IsNullOrWhiteSpace(details.Notes))
                        {
                            <p class="text-white-50 small mt-2 mb-0"><i class="bi bi-info-circle me-1"></i>Notes: @details.Notes</p>
                        }
                    </div>
                    <div class="col-md-4 text-md-end mt-4 mt-md-0">
                        <i class="bi bi-truck display-1 text-white-50"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Analytical Stats Cards Grid -->
        <div class="row g-4 mb-4">
            <!-- Stat 1: Total Medicines Supplied -->
            <div class="col-md-4 col-lg">
                <div class="card border-0 shadow-sm rounded-4 stat-card bg-white p-3 h-100">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <span class="text-secondary small fw-medium">Medicines Supplied</span>
                        <div class="icon-shape bg-primary-subtle text-primary rounded-3 px-2 py-1"><i class="bi bi-capsule fs-5"></i></div>
                    </div>
                    <h3 class="fw-bold mb-1 text-dark">@details.TotalMedicines</h3>
                    <p class="text-muted extra-small mb-0">Total unique drug types</p>
                </div>
            </div>

            <!-- Stat 2: Total Stock -->
            <div class="col-md-4 col-lg">
                <div class="card border-0 shadow-sm rounded-4 stat-card bg-white p-3 h-100">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <span class="text-secondary small fw-medium">Supplier Stock Units</span>
                        <div class="icon-shape bg-info-subtle text-info rounded-3 px-2 py-1"><i class="bi bi-box-seam fs-5"></i></div>
                    </div>
                    <h3 class="fw-bold mb-1 text-dark">@details.TotalStock</h3>
                    <p class="text-muted extra-small mb-0">Units physically on shelf</p>
                </div>
            </div>

            <!-- Stat 4: Supplier Stock Value (SQL DB Function) -->
            <div class="col-md-6 col-lg">
                <div class="card border-0 shadow-sm rounded-4 stat-card bg-white p-3 h-100" style="border-left: 4px solid #6f42c1 !important;">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <span class="text-secondary small fw-medium">Func Stock Value</span>
                        <div class="icon-shape rounded-3 px-2 py-1" style="background-color: #f3e8ff; color: #6f42c1;"><i class="bi bi-database-fill-gear fs-5"></i></div>
                    </div>
                    <h3 class="fw-bold mb-1" style="color: #6f42c1;">@details.SupplierStockValueFromFunc.ToString("C")</h3>
                    <p class="text-muted extra-small mb-0">Calculated via <code>fn_GetSupplierStockValue</code></p>
                </div>
            </div>

            <!-- Stat 5: Top-Selling Medicine -->
            <div class="col-md-6 col-lg">
                <div class="card border-0 shadow-sm rounded-4 stat-card bg-white p-3 h-100">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <span class="text-secondary small fw-medium">Top Selling Medicine</span>
                        <div class="icon-shape bg-warning-subtle text-warning rounded-3 px-2 py-1"><i class="bi bi-trophy fs-5"></i></div>
                    </div>
                    @if (details.TopMedicineName != null)
                    {
                        <h4 class="fw-bold mb-1 text-dark text-truncate" title="@details.TopMedicineName">@details.TopMedicineName</h4>
                        <p class="text-muted extra-small mb-0">Revenue: <strong>@details.TopMedicineRevenue.ToString("C")</strong></p>
                    }
                    else
                    {
                        <h4 class="fw-bold mb-1 text-secondary">None</h4>
                        <p class="text-muted extra-small mb-0">No sales recorded yet</p>
                    }
                </div>
            </div>
        </div>

        <!-- Supplier Base Info and Audit Card -->
        <div class="card border-0 shadow-sm rounded-4 mb-4">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3 text-dark"><i class="bi bi-file-earmark-medical-fill text-primary me-2"></i>Audit Information</h5>
                <div class="row g-3">
                    <div class="col-sm-6 col-md-4">
                        <div class="text-muted small">Last Audit Date</div>
                        <div class="fw-bold text-dark fs-6">@details.LastAuditDate.ToString("f")</div>
                    </div>
                    <div class="col-sm-6 col-md-4">
                        <div class="text-muted small">Audit Status</div>
                        <div>
                            @if ((DateTime.Now - details.LastAuditDate).TotalDays > 365)
                            {
                                <span class="badge bg-danger px-3 py-2 rounded-pill"><i class="bi bi-exclamation-octagon me-1"></i>Audit Overdue</span>
                            }
                            else
                            {
                                <span class="badge bg-success px-3 py-2 rounded-pill"><i class="bi bi-check-circle me-1"></i>Audit Up-To-Date</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Supplied Medicines Catalog Table -->
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
            <div class="card-header bg-white border-0 pt-4 px-4 pb-2">
                <h5 class="fw-bold mb-0 text-dark"><i class="bi bi-collection-play-fill text-primary me-2"></i>Medicines Supplied</h5>
            </div>
            <div class="card-body p-0">
                @if (details.Medicines == null || !details.Medicines.Any())
                {
                    <div class="text-center py-5">
                        <div class="mb-3 text-muted">
                            <i class="bi bi-journal-x display-4"></i>
                        </div>
                        <h6 class="fw-semibold text-secondary">No medicines currently registered for this supplier.</h6>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">ID</th>
                                    <th>Medicine Name</th>
                                    <th class="text-end">Base Price</th>
                                    <th class="text-end">Available Stock</th>
                                    <th class="text-center" style="width: 150px;">Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var med in details.Medicines)
                                {
                                    <tr>
                                        <td class="ps-4">
                                            <span class="badge bg-secondary-subtle text-secondary-emphasis font-monospace px-2 py-1 fs-7">#@med.MedicineId</span>
                                        </td>
                                        <td>
                                            <a href="/medicines/@med.MedicineId" class="fw-bold text-primary text-decoration-none">@med.Name</a>
                                        </td>
                                        <td class="text-end fw-semibold text-dark">
                                            @med.BasePrice.ToString("C")
                                        </td>
                                        <td class="text-end font-monospace">
                                            <span class="badge bg-light text-dark border px-2 py-1">@med.TotalStock</span>
                                        </td>
                                        <td class="text-center">
                                            @if (med.IsActive)
                                            {
                                                <span class="badge bg-success px-2 py-1 rounded-pill">Active</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger px-2 py-1 rounded-pill">Inactive</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }
</div>



@code {
    [Parameter]
    public int SupplierId { get; set; }

    private SupplierDetailsDto? details;
    private bool isLoading = true;

    // Edit/Delete UI state
    private bool isEditMode = false;
    private bool isDeleteConfirm = false;
    private bool isActionLoading = false;
    private bool showActionSuccess = false;
    private string? actionError;

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        try
        {
            details = await Mediator.Send(new GetSupplierDetailsQuery(SupplierId));
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading supplier details for SupplierId={SupplierId}", SupplierId);
        }
        finally
        {
            isLoading = false;
        }
    }

    private void EnterEditMode()
    {
        actionError = null;
        showActionSuccess = false;
        isEditMode = true;
        isDeleteConfirm = false;
    }

    private void EnterDeleteConfirm()
    {
        actionError = null;
        showActionSuccess = false;
        isDeleteConfirm = true;
        isEditMode = false;
    }

    private void CancelAction()
    {
        isEditMode = false;
        isDeleteConfirm = false;
        actionError = null;
    }

    private async Task HandleEditSuccess()
    {
        isLoading = true;
        showActionSuccess = false;
        actionError = null;

        try
        {
            details = await Mediator.Send(new GetSupplierDetailsQuery(SupplierId));
            isEditMode = false;
            showActionSuccess = true;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error refreshing supplier details after save.");
            actionError = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ConfirmDelete()
    {
        isActionLoading = true;
        actionError = null;

        try
        {
            await Mediator.Send(new DeleteSupplierCommand(SupplierId));
            NavigationManager.NavigateTo("/suppliers");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error deleting supplier {SupplierId}.", SupplierId);
            actionError = ex.Message;
            isDeleteConfirm = false;
        }
        finally
        {
            isActionLoading = false;
        }
    }
}
