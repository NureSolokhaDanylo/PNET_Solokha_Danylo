@page "/medicines"
@rendermode InteractiveServer
@using PNET_Solokha_Danylo.Application.Medicines.Queries.GetMedicines
@using PNET_Solokha_Danylo.Application.Medicines.Queries.GetExpensiveMedicinesCount
@using PNET_Solokha_Danylo.Application.Suppliers.Queries.GetSuppliers
@using PNET_Solokha_Danylo.Domain.Entities
@using PNET_Solokha_Danylo.Blazor.Components.Medicines
@inject IMediator Mediator
@inject ILogger<Medicines> Logger


<PageTitle>Medicine Management</PageTitle>

<div class="container-fluid py-4">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="display-6 fw-bold text-gradient">Pharmaceutical Catalog</h1>
            <p class="text-muted mb-0">Record, categorize, and control the active catalog of warehouse medicines.</p>
        </div>
        <div class="badge bg-primary px-3 py-2 fs-6 rounded-pill shadow-sm">
            Total Medicines: @totalCount
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <AddMedicineForm OnMedicineAdded="FetchDataWithReset" />

            <!-- DB Function 1.3.3.1 Import Analytics Widget -->
            <div class="card border-0 shadow-sm rounded-4 mt-4">
                <div class="card-header bg-white border-0 pt-4 px-4 pb-2">
                    <h5 class="fw-bold mb-0 text-dark">
                        <i class="bi bi-graph-up-arrow text-primary me-2"></i>Import Analytics
                    </h5>
                </div>
                <div class="card-body px-4 pb-4">
                    <p class="text-secondary small mb-4">Calculate how many medicines in stock are priced higher than the average cost of drugs from a specific supplier country.</p>
                    
                    @if (countries == null || !countries.Any())
                    {
                        <div class="text-center py-3 text-muted small">
                            <i class="bi bi-info-circle me-1"></i> No supplier countries available
                        </div>
                    }
                    else
                    {
                        <div class="mb-4">
                            <label class="form-label text-secondary small fw-semibold mb-2">Select Supplier Country</label>
                            <select class="form-select rounded-3 text-dark border" 
                                    value="@selectedCountry" 
                                    @onchange="OnCountryChanged">
                                @foreach (var country in countries)
                                {
                                    <option value="@country">@country</option>
                                }
                            </select>
                        </div>
                        
                        <div class="text-center py-3 rounded-3 bg-light border">
                            @if (isCalculating)
                            {
                                <div class="spinner-border spinner-border-sm text-primary my-3" role="status">
                                    <span class="visually-hidden">Calculating...</span>
                                </div>
                                <div class="small text-secondary">Querying database...</div>
                            }
                            else
                            {
                                <h1 class="display-3 fw-bold text-primary mb-0 font-monospace">@expensiveCount</h1>
                                <div class="small text-secondary text-uppercase tracking-wider fw-bold">Costly Drugs</div>
                                <div class="extra-small text-muted mt-1">priced above average for <strong>@selectedCountry</strong></div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
        
        <div class="col-md-8">
            <MedicineFilterBar 
                @bind-SearchTerm="searchTerm"
                @bind-FilterIsActiveString="filterIsActiveString"
                @bind-FilterCategoryId="filterCategoryId"
                @bind-FilterSupplierId="filterSupplierId"
                OnFiltersApplied="ApplyFilters"
                OnFiltersReset="ResetFilters" />

            <MedicineTable 
                Medicines="medicines"
                IsLoading="isLoading"
                TotalCount="totalCount"
                Skip="skip"
                Take="take"
                OnPageChanged="HandlePageChanged" />
        </div>
    </div>
</div>

@code {
    private List<Medicine>? medicines;
    private int totalCount;
    private bool isLoading = true;

    private string? searchTerm;
    private string filterIsActiveString = "all";
    private int? filterCategoryId;
    private int? filterSupplierId;

    private bool? filterIsActive => filterIsActiveString switch
    {
        "active" => true,
        "inactive" => false,
        _ => null
    };

    private int skip = 0;
    private int take = 10;

    // Premium Analytics variables
    private List<string> countries = new();
    private string? selectedCountry;
    private int expensiveCount;
    private bool isCalculating = false;

    protected override async Task OnInitializedAsync()
    {
        Logger.LogInformation("Initializing Medicines page.");
        await FetchData();
        
        // Fetch countries for Premium Analytics
        try
        {
            var suppliersResult = await Mediator.Send(new GetSuppliersQuery());
            countries = suppliersResult.Items
                .Select(s => s.Country)
                .Where(c => !string.IsNullOrWhiteSpace(c))
                .Distinct()
                .OrderBy(c => c)
                .ToList();
                
            if (countries.Any())
            {
                selectedCountry = countries.First();
                await CalculateExpensiveCount();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading supplier countries.");
        }
    }

    private async Task CalculateExpensiveCount()
    {
        if (string.IsNullOrWhiteSpace(selectedCountry))
        {
            expensiveCount = 0;
            return;
        }

        isCalculating = true;
        StateHasChanged();
        try
        {
            expensiveCount = await Mediator.Send(new GetExpensiveMedicinesCountQuery(selectedCountry));
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error calculating expensive medicines count for country={Country}", selectedCountry);
        }
        finally
        {
            isCalculating = false;
            StateHasChanged();
        }
    }

    private async Task OnCountryChanged(ChangeEventArgs e)
    {
        selectedCountry = e.Value?.ToString();
        await CalculateExpensiveCount();
    }

    private async Task FetchDataWithReset()
    {
        skip = 0;
        await FetchData();
    }

    private async Task FetchData(bool showSpinner = true)
    {
        if (showSpinner)
        {
            isLoading = true;
            StateHasChanged();
        }

        try
        {
            var query = new GetMedicinesQuery(
                SearchTerm: searchTerm,
                CategoryId: filterCategoryId,
                SupplierId: filterSupplierId,
                IsActive: filterIsActive,
                Skip: skip,
                Take: take
            );

            var result = await Mediator.Send(query);
            medicines = result.Items;
            totalCount = result.TotalCount;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error fetching medicines.");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task ApplyFilters()
    {
        skip = 0;
        await FetchData();
    }

    private async Task ResetFilters()
    {
        skip = 0;
        await FetchData();
    }

    private async Task HandlePageChanged((int Skip, int Take) pageInfo)
    {
        skip = pageInfo.Skip;
        take = pageInfo.Take;
        await FetchData(showSpinner: false);
    }
}
