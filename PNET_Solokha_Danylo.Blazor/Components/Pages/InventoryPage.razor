@page "/inventory"
@rendermode InteractiveServer
@using PNET_Solokha_Danylo.Application.Inventories.Queries.GetInventories
@using PNET_Solokha_Danylo.Blazor.Components.Inventory
@inject IMediator Mediator
@inject ILogger<InventoryPage> Logger

<PageTitle>Inventory Management</PageTitle>

<div class="container-fluid py-4">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="display-6 fw-bold text-gradient">Inventory Stock</h1>
            <p class="text-muted mb-0">Record and manage pharmaceutical batches, shelf locations, and expiry dates.</p>
        </div>
        <div class="badge bg-primary px-3 py-2 fs-6 rounded-pill shadow-sm">
            Total Batches: @totalCount
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <AddInventoryForm OnInventoryAdded="FetchDataWithReset" />
        </div>

        <div class="col-md-8">
            <InventoryFilterBar 
                @bind-SearchTerm="searchTerm"
                @bind-FilterMedicineId="filterMedicineId"
                OnFiltersApplied="ApplyFilters"
                OnFiltersReset="ResetFilters" />

            <InventoryTable 
                Inventories="inventories"
                IsLoading="isLoading"
                TotalCount="totalCount"
                Skip="skip"
                Take="take"
                OnPageChanged="HandlePageChanged" />
        </div>
    </div>
</div>

@code {
    private List<InventoryDto>? inventories;
    private int totalCount;
    private bool isLoading = true;

    private string? searchTerm;
    private int? filterMedicineId;

    private int skip = 0;
    private int take = 10;

    protected override async Task OnInitializedAsync()
    {
        Logger.LogInformation("Initializing InventoryPage component.");
        await FetchData();
    }

    private async Task FetchDataWithReset()
    {
        skip = 0;
        await FetchData();
    }

    private async Task FetchData()
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            var query = new GetInventoriesQuery(
                SearchTerm: searchTerm,
                MedicineId: filterMedicineId,
                Skip: skip,
                Take: take
            );

            var result = await Mediator.Send(query);
            inventories = result.Items;
            totalCount = result.TotalCount;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error fetching inventories.");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task ApplyFilters()
    {
        skip = 0;
        await FetchData();
    }

    private async Task ResetFilters()
    {
        skip = 0;
        await FetchData();
    }

    private async Task HandlePageChanged((int Skip, int Take) pageInfo)
    {
        skip = pageInfo.Skip;
        take = pageInfo.Take;
        await FetchData();
    }
}
