@page "/sales-archive"
@rendermode InteractiveServer
@inject IMediator Mediator
@inject ILogger<SalesArchivePage> Logger

<PageTitle>Sales Archive</PageTitle>

<div class="container-fluid py-4">
    <!-- Header with Gradient Title -->
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="display-6 fw-bold text-gradient">Sales Archive</h1>
            <p class="text-muted mb-0">View, search, and filter archived pharmaceutical sales records.</p>
        </div>
        <div class="badge bg-primary px-3 py-2 fs-6 rounded-pill shadow-sm">
            Total Archives: @totalCount
        </div>
    </div>

    <!-- Filter Card with Glassmorphic Styling -->
    <div class="card border-0 shadow-sm mb-4 rounded-4 filter-card">
        <div class="card-body p-4">
            <h5 class="fw-semibold mb-3 d-flex align-items-center">
                <i class="bi bi-funnel-fill text-primary me-2"></i> Filters & Search
            </h5>
            <div class="row g-3">
                <!-- Search term -->
                <div class="col-md-4">
                    <label class="form-label text-secondary small fw-medium">Search Reason or Medicine</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                        <input type="text" class="form-control border-start-0 ps-0" placeholder="e.g. Broken package, Paracetamol..." @bind="searchTerm" @bind:event="oninput" @onkeyup="OnSearchKeyUp" />
                        @if (!string.IsNullOrEmpty(searchTerm))
                        {
                            <button class="btn btn-outline-secondary" type="button" @onclick="ClearSearch">
                                <i class="bi bi-x-lg"></i>
                            </button>
                        }
                    </div>
                </div>

                <!-- Medicine ID -->
                <div class="col-md-2">
                    <label class="form-label text-secondary small fw-medium">Medicine ID</label>
                    <input type="number" class="form-control" placeholder="Any" @bind="medicineId" @bind:event="oninput" @onkeyup="OnSearchKeyUp" />
                </div>

                <!-- Sale ID -->
                <div class="col-md-2">
                    <label class="form-label text-secondary small fw-medium">Sale ID</label>
                    <input type="number" class="form-control" placeholder="Any" @bind="saleId" @bind:event="oninput" @onkeyup="OnSearchKeyUp" />
                </div>

                <!-- Start Date -->
                <div class="col-md-2">
                    <label class="form-label text-secondary small fw-medium">Archived From</label>
                    <input type="date" class="form-control" @bind="startDate" />
                </div>

                <!-- End Date -->
                <div class="col-md-2">
                    <label class="form-label text-secondary small fw-medium">Archived To</label>
                    <input type="date" class="form-control" @bind="endDate" />
                </div>
            </div>

            <!-- Action buttons -->
            <div class="d-flex justify-content-end gap-2 mt-4">
                <button class="btn btn-light px-4 rounded-3 text-secondary" @onclick="ResetFilters">
                    <i class="bi bi-arrow-counterclockwise me-1"></i> Reset
                </button>
                <button class="btn btn-primary px-4 rounded-3" @onclick="ApplyFilters">
                    <i class="bi bi-search me-1"></i> Apply Filters
                </button>
            </div>
        </div>
    </div>

    <!-- Data Table -->
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-0">
            @if (isLoading)
            {
                <div class="d-flex flex-column align-items-center justify-content-center py-5">
                    <div class="spinner-border text-primary mb-3" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <span class="text-secondary">Fetching archived sales...</span>
                </div>
            }
            else if (archives == null || !archives.Any())
            {
                <div class="text-center py-5">
                    <div class="mb-3 text-muted">
                        <i class="bi bi-folder-x display-3"></i>
                    </div>
                    <h5 class="fw-semibold text-dark">No records found</h5>
                    <p class="text-muted px-4">Try adjusting your filters or search terms to find what you are looking for.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">Archive ID</th>
                                <th>Sale ID</th>
                                <th>Medicine</th>
                                <th class="text-center">Quantity</th>
                                <th>Sale Date</th>
                                <th>Archived At</th>
                                <th>Reason</th>
                                <th class="pe-4 text-end">Details</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var sa in archives)
                            {
                                var isExpanded = expandedRows.Contains(sa.ArchiveId);
                                <tr>
                                    <td class="ps-4">
                                        <a href="/sales-archive/@sa.ArchiveId" class="badge bg-secondary-subtle text-secondary-emphasis font-monospace px-2 py-1 fs-7 text-decoration-none">#@sa.ArchiveId</a>
                                    </td>
                                    <td>
                                        @if (sa.SaleId.HasValue)
                                        {
                                            <a href="/sales/@sa.SaleId" class="text-primary font-monospace text-decoration-none">@sa.SaleId</a>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="d-flex flex-column">
                                            @if (sa.MedicineId.HasValue)
                                            {
                                                <a href="/medicines/@sa.MedicineId" class="fw-semibold text-primary text-decoration-none">@sa.MedicineName</a>
                                            }
                                            else
                                            {
                                                <span class="fw-semibold text-dark">@sa.MedicineName</span>
                                            }
                                            <span class="text-muted small">ID: @(sa.MedicineId?.ToString() ?? "N/A")</span>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <span class="fw-bold text-primary">@sa.Quantity</span>
                                    </td>
                                    <td>
                                        <span class="text-secondary small">@(sa.SaleDate?.ToString("yyyy-MM-dd HH:mm") ?? "—")</span>
                                    </td>
                                    <td>
                                        <span class="text-secondary small">@sa.ArchivedAt.ToString("yyyy-MM-dd HH:mm")</span>
                                    </td>
                                    <td>
                                        <div class="text-truncate text-secondary" style="max-width: 250px;" title="@sa.Reason">
                                            @sa.Reason
                                        </div>
                                    </td>
                                    <td class="pe-4 text-end">
                                        <button class="btn btn-sm btn-icon btn-light-primary rounded-circle" @onclick="() => ToggleRow(sa.ArchiveId)" aria-label="Toggle details">
                                            <i class="bi @(isExpanded ? "bi-chevron-up" : "bi-chevron-down")"></i>
                                        </button>
                                    </td>
                                </tr>
                                @if (isExpanded)
                                {
                                    <tr class="table-detail-row">
                                        <td colspan="8" class="bg-light-subtle ps-4 pe-4 py-3">
                                            <div class="p-3 bg-white rounded-3 border shadow-sm">
                                                <h6 class="fw-bold text-dark border-bottom pb-2 mb-3">Archive Detail View</h6>
                                                <div class="row g-3">
                                                    <div class="col-sm-6 col-md-3">
                                                        <div class="small text-muted">Archive ID</div>
                                                        <div class="fw-semibold font-monospace">@sa.ArchiveId</div>
                                                    </div>
                                                    <div class="col-sm-6 col-md-3">
                                                        <div class="small text-muted">Original Sale ID</div>
                                                        <div class="fw-semibold font-monospace">@(sa.SaleId?.ToString() ?? "None")</div>
                                                    </div>
                                                    <div class="col-sm-6 col-md-3">
                                                        <div class="small text-muted">Medicine</div>
                                                        <div class="fw-semibold">@sa.MedicineName (ID: @(sa.MedicineId?.ToString() ?? "N/A"))</div>
                                                    </div>
                                                    <div class="col-sm-6 col-md-3">
                                                        <div class="small text-muted">Quantity</div>
                                                        <div class="fw-semibold text-primary">@sa.Quantity</div>
                                                    </div>
                                                    <div class="col-sm-6 col-md-4">
                                                        <div class="small text-muted">Original Sale Date</div>
                                                        <div class="fw-semibold">@(sa.SaleDate?.ToString("f") ?? "Unknown")</div>
                                                    </div>
                                                    <div class="col-sm-6 col-md-4">
                                                        <div class="small text-muted">Archive Timestamp</div>
                                                        <div class="fw-semibold text-secondary">@sa.ArchivedAt.ToString("f")</div>
                                                    </div>
                                                    <div class="col-12 mt-3">
                                                        <div class="small text-muted mb-1">Archival Reason</div>
                                                        <div class="p-3 bg-light rounded text-dark font-monospace border-start border-4 border-warning small">
                                                            @(string.IsNullOrWhiteSpace(sa.Reason) ? "No reason specified." : sa.Reason)
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Footer Pagination -->
                <PaginationControl TotalCount="totalCount" Skip="skip" PageSize="take" OnPageChanged="HandlePageChanged" />
            }
        </div>
    </div>
</div>



@using PNET_Solokha_Danylo.Blazor.Components.Common
@code {
    private List<SalesArchiveDto>? archives;
    private int totalCount;
    private bool isLoading = true;

    // Filters state
    private string? searchTerm;
    private int? medicineId;
    private int? saleId;
    private DateTime? startDate;
    private DateTime? endDate;

    // Pagination state
    private int skip = 0;
    private int take = 10;



    // Expanded detail rows
    private HashSet<int> expandedRows = new();

    protected override async Task OnInitializedAsync()
    {
        Logger.LogInformation("Initializing SalesArchivePage component.");
        await FetchData();
    }

    private async Task FetchData()
    {
        isLoading = true;
        expandedRows.Clear();
        StateHasChanged();

        try
        {
            var query = new GetSalesArchivesQuery(
                SearchTerm: searchTerm,
                MedicineId: medicineId,
                SaleId: saleId,
                StartDate: startDate,
                EndDate: endDate,
                Skip: skip,
                Take: take
            );

            var result = await Mediator.Send(query);
            archives = result.Items;
            totalCount = result.TotalCount;
            
            Logger.LogInformation("Fetched {Count} archives (Total {Total}).",
                archives?.Count ?? 0, totalCount);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error fetching sales archives.");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task ApplyFilters()
    {
        skip = 0; // reset to first page when filtering
        await FetchData();
    }

    private async Task ResetFilters()
    {
        searchTerm = null;
        medicineId = null;
        saleId = null;
        startDate = null;
        endDate = null;
        skip = 0;
        await FetchData();
    }

    private async Task ClearSearch()
    {
        searchTerm = null;
        await ApplyFilters();
    }

    private async Task OnSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await ApplyFilters();
        }
    }

    private async Task HandlePageChanged((int Skip, int Take) pageInfo)
    {
        skip = pageInfo.Skip;
        take = pageInfo.Take;
        await FetchData();
    }

    private void ToggleRow(int archiveId)
    {
        if (expandedRows.Contains(archiveId))
        {
            expandedRows.Remove(archiveId);
        }
        else
        {
            expandedRows.Add(archiveId);
        }
    }
}
