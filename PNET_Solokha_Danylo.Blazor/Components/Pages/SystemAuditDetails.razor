@page "/system-audit/{LogId:int}"
@rendermode InteractiveServer
@using PNET_Solokha_Danylo.Application.SystemAudits.Queries.GetSystemAuditDetails
@inject IMediator Mediator
@inject NavigationManager NavigationManager
@inject ILogger<SystemAuditDetails> Logger

<PageTitle>Audit Log Entry - #@LogId</PageTitle>

<div class="container-fluid py-4">
    <!-- Breadcrumb & Back Nav -->
    <div class="mb-4 d-flex align-items-center justify-content-between">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="system-audit" class="text-primary text-decoration-none">System Audit</a></li>
                <li class="breadcrumb-item active" aria-current="page">Details</li>
            </ol>
        </nav>
        <a href="system-audit" class="btn btn-outline-secondary btn-sm rounded-3">
            <i class="bi bi-arrow-left me-1"></i> Back to List
        </a>
    </div>

    @if (isLoading)
    {
        <div class="d-flex flex-column align-items-center justify-content-center py-5">
            <div class="spinner-border text-primary mb-3" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <span class="text-secondary">Fetching audit entry details...</span>
        </div>
    }
    else if (details == null)
    {
        <div class="alert alert-danger rounded-4 p-4 shadow-sm" role="alert">
            <div class="d-flex align-items-center">
                <i class="bi bi-exclamation-triangle-fill fs-2 me-3 text-danger"></i>
                <div>
                    <h5 class="alert-heading fw-bold mb-1">Audit Entry Not Found</h5>
                    <p class="mb-0">The requested system audit log with ID #@LogId does not exist in the database.</p>
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- Header Banner Section -->
        <div class="card border-0 shadow-sm rounded-4 mb-4 overflow-hidden @HeaderClass">
            <div class="card-body p-4 p-md-5 text-white">
                <div class="row align-items-center">
                    <div class="col-md-8">
                        <span class="badge bg-white bg-opacity-25 text-white px-3 py-2 rounded-pill fs-7 mb-3 font-monospace border border-white border-opacity-25">
                            Severity: @details.Severity
                        </span>
                        <h1 class="display-5 fw-bold mb-2 text-white">Audit Log: #@details.LogId</h1>
                        <p class="lead mb-0 text-white-50"><i class="bi bi-shield-lock-fill me-2"></i>Action: <strong>@details.ActionType</strong> on <strong>@details.TableName</strong></p>
                    </div>
                    <div class="col-md-4 text-md-end mt-4 mt-md-0">
                        <i class="bi @(details.Severity == "ERROR" || details.Severity == "CRITICAL" ? "bi-shield-slash" : "bi-shield-fill-check") display-1 text-white-50"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Metadata & Context Card -->
        <div class="card border-0 shadow-sm rounded-4 mb-4">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-4 text-dark"><i class="bi bi-info-circle-fill text-primary me-2"></i>Audit Context Details</h5>
                
                <div class="row g-3 mb-4">
                    <div class="col-sm-6 col-md-3">
                        <div class="text-muted small">Impacted Table</div>
                        <div class="fw-bold text-dark fs-6 mt-1 font-monospace">@details.TableName</div>
                    </div>
                    <div class="col-sm-6 col-md-3">
                        <div class="text-muted small">Impacted Record Link</div>
                        <div class="fw-bold text-dark fs-6 mt-1">
                            @if (details.RecordId.HasValue && details.TableName != null)
                            {
                                <a href="@GetEntityDetailsLink(details.TableName, details.RecordId.Value)" class="text-primary text-decoration-none">
                                    <i class="bi bi-link-45deg me-1"></i>View Record #@details.RecordId.Value
                                </a>
                            }
                            else if (details.RecordId.HasValue)
                            {
                                <span class="font-monospace text-secondary">ID: #@details.RecordId.Value</span>
                            }
                            else
                            {
                                <span class="text-secondary">—</span>
                            }
                        </div>
                    </div>
                    <div class="col-sm-6 col-md-3">
                        <div class="text-muted small">Impacted Column</div>
                        <div class="fw-bold text-dark fs-6 mt-1 font-monospace">@(details.ColumnName ?? "Entire Row / All Columns")</div>
                    </div>
                    <div class="col-sm-6 col-md-3">
                        <div class="text-muted small">Triggered By User</div>
                        <div class="fw-bold text-dark fs-6 mt-1"><i class="bi bi-person me-1"></i>@(details.UserName ?? "SQL System Trigger")</div>
                    </div>
                </div>

                <div class="row g-3">
                    <div class="col-sm-6">
                        <div class="text-muted small">Audit Event Timestamp</div>
                        <div class="fw-bold text-dark fs-6 mt-1">@details.LogDate.ToString("f")</div>
                    </div>
                    @if (!string.IsNullOrEmpty(details.AdditionalInfo))
                    {
                        <div class="col-12 mt-3">
                            <div class="text-muted small mb-1">Additional Diagnostic Info</div>
                            <div class="p-3 bg-light rounded text-dark font-monospace border small">@details.AdditionalInfo</div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Comparison Side-By-Side View -->
        <div class="row g-4 mb-4">
            <!-- Old Value Column -->
            <div class="col-md-6">
                <div class="card border-0 shadow-sm rounded-4 h-100 bg-white">
                    <div class="card-header bg-danger-subtle border-0 pt-3 px-4 pb-2">
                        <h6 class="fw-bold text-danger mb-0"><i class="bi bi-dash-circle-fill me-2"></i>Old Database State / Value</h6>
                    </div>
                    <div class="card-body px-4 py-3">
                        @if (string.IsNullOrEmpty(details.OldValue))
                        {
                            <span class="text-muted small"><em>No previous value logged (record inserted).</em></span>
                        }
                        else
                        {
                            <pre class="bg-light p-3 rounded font-monospace text-wrap border mb-0 small">@details.OldValue</pre>
                        }
                    </div>
                </div>
            </div>

            <!-- New Value Column -->
            <div class="col-md-6">
                <div class="card border-0 shadow-sm rounded-4 h-100 bg-white">
                    <div class="card-header bg-success-subtle border-0 pt-3 px-4 pb-2">
                        <h6 class="fw-bold text-success mb-0"><i class="bi bi-plus-circle-fill me-2"></i>New Database State / Value</h6>
                    </div>
                    <div class="card-body px-4 py-3">
                        @if (string.IsNullOrEmpty(details.NewValue))
                        {
                            <span class="text-muted small"><em>No new value logged (record deleted).</em></span>
                        }
                        else
                        {
                            <pre class="bg-light p-3 rounded font-monospace text-wrap border mb-0 small">@details.NewValue</pre>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Correlated Change History Timeline -->
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
            <div class="card-header bg-white border-0 pt-4 px-4 pb-2">
                <h5 class="fw-bold mb-0 text-dark"><i class="bi bi-clock-history text-primary me-2"></i>Correlated Record Timeline</h5>
                <p class="text-muted extra-small mb-0 mt-1">Other audit events recorded for table <strong>@details.TableName</strong> and row <strong>#@details.RecordId</strong></p>
            </div>
            <div class="card-body p-4">
                @if (details.RelatedHistory == null || !details.RelatedHistory.Any())
                {
                    <div class="text-center py-4 text-muted">
                        <i class="bi bi-calendar-event display-4 d-block mb-3"></i>
                        <h6>No other audit logs exist for this record.</h6>
                    </div>
                }
                else
                {
                    <div class="timeline-container bg-light p-3 rounded-4 border">
                        @foreach (var log in details.RelatedHistory)
                        {
                            <div class="timeline-item d-flex gap-3 mb-4 pb-3 border-bottom border-light-subtle last-no-border">
                                <div class="timeline-badge bg-primary text-white rounded-circle p-2 d-flex align-items-center justify-content-center" style="width: 38px; height: 38px;">
                                    <i class="bi bi-shield-check"></i>
                                </div>
                                <div class="timeline-content flex-grow-1">
                                    <div class="d-flex align-items-center justify-content-between mb-1">
                                        <a href="/system-audit/@log.LogId" class="fw-bold text-dark text-decoration-none hover-link">Audit Entry #@log.LogId</a>
                                        <span class="text-muted extra-small">@log.LogDate.ToString("f")</span>
                                    </div>
                                    <div class="small text-secondary mb-1">
                                        Action <strong>@log.ActionType</strong> on column <code class="font-monospace text-primary bg-light px-1">@(log.ColumnName ?? "All")</code>
                                    </div>
                                    <div class="extra-small text-muted">
                                        <i class="bi bi-person me-1"></i>User: @(log.UserName ?? "SQL System Trigger")
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    }
</div>

<style>
    .header-info {
        background: linear-gradient(135deg, #4b6cb7 0%, #182848 100%);
    }
    .header-warning {
        background: linear-gradient(135deg, #f12711 0%, #f5af19 100%);
    }
    .header-danger {
        background: linear-gradient(135deg, #cb2d3e 0%, #ef473a 100%);
    }
    .hover-link:hover {
        color: #fff !important;
        text-decoration: underline !important;
    }
    .fs-7 {
        font-size: 0.8rem;
    }
    .extra-small {
        font-size: 0.72rem;
    }
    .last-no-border:last-child {
        border-bottom: 0 !important;
        margin-bottom: 0 !important;
        pb-0 !important;
    }
</style>

@code {
    [Parameter]
    public int LogId { get; set; }

    private SystemAuditDetailsDto? details;
    private bool isLoading = true;

    private string HeaderClass => details?.Severity switch
    {
        "ERROR" or "CRITICAL" => "header-danger",
        "WARNING" => "header-warning",
        _ => "header-info"
    };

    protected override async Task OnParametersSetAsync()
    {
        Logger.LogInformation("Loading details for LogId={LogId}", LogId);
        isLoading = true;
        try
        {
            details = await Mediator.Send(new GetSystemAuditDetailsQuery(LogId));
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading audit details for LogId={LogId}", LogId);
        }
        finally
        {
            isLoading = false;
        }
    }

    private string GetEntityDetailsLink(string tableName, int recordId) => tableName.ToLower() switch
    {
        "categories" => $"/categories/{recordId}",
        "suppliers" => $"/suppliers/{recordId}",
        "medicines" => $"/medicines/{recordId}",
        "inventory" => $"/inventory/{recordId}",
        "sales" => $"/sales/{recordId}",
        "salesarchive" => $"/sales-archive/{recordId}",
        _ => "#"
    };
}
