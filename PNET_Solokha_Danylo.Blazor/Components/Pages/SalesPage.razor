@page "/sales"
@rendermode InteractiveServer
@using PNET_Solokha_Danylo.Application.Sales.Queries.GetSales
@using PNET_Solokha_Danylo.Blazor.Components.Sales
@inject IMediator Mediator
@inject ILogger<SalesPage> Logger

<PageTitle>Sales Management</PageTitle>

<div class="container-fluid py-4">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="display-6 fw-bold text-gradient">Sales Registration & Tracking</h1>
            <p class="text-muted mb-0">Manage pharmaceutical transactions, verify product stock availability, and track sales revenue.</p>
        </div>
        <div class="badge bg-primary px-3 py-2 fs-6 rounded-pill shadow-sm">
            Total Sales: @totalCount
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <SalesRegistrationForm OnSaleRegistered="FetchData" />
            <ArchiveSalesPanel OnArchiveCompleted="FetchData" />
        </div>

        <div class="col-lg-8">
            <SalesFilterBar 
                @bind-SearchTerm="searchTerm" 
                @bind-FilterMedicineId="filterMedicineId" 
                @bind-StartDate="startDate" 
                @bind-EndDate="endDate" 
                OnFiltersApplied="ApplyFilters" 
                OnFiltersReset="ResetFilters" />

            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <SalesTable 
                    Sales="sales" 
                    IsLoading="isLoading" 
                    TotalCount="totalCount" 
                    Skip="skip" 
                    Take="take" 
                    OnPageChanged="HandlePageChanged" />
            </div>
        </div>
    </div>
</div>

@code {
    private List<SaleDto>? sales;
    private int totalCount;
    private bool isLoading = true;

    private string? searchTerm;
    private int? filterMedicineId;
    private DateTime? startDate;
    private DateTime? endDate;

    private int skip = 0;
    private int take = 10;

    protected override async Task OnInitializedAsync()
    {
        Logger.LogInformation("Initializing SalesPage component.");
        await FetchData();
    }

    private async Task FetchData()
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            var query = new GetSalesQuery(
                SearchTerm: searchTerm,
                MedicineId: filterMedicineId,
                StartDate: startDate,
                EndDate: endDate,
                Skip: skip,
                Take: take
            );

            var result = await Mediator.Send(query);
            sales = result.Items;
            totalCount = result.TotalCount;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error fetching sales.");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task ApplyFilters()
    {
        skip = 0;
        await FetchData();
    }

    private async Task ResetFilters()
    {
        skip = 0;
        await FetchData();
    }

    private async Task HandlePageChanged((int Skip, int Take) pageInfo)
    {
        skip = pageInfo.Skip;
        take = pageInfo.Take;
        await FetchData();
    }
}
