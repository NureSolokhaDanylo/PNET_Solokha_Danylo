@using PNET_Solokha_Danylo.Application.Inventories.Queries.GetInventories
@using PNET_Solokha_Danylo.Blazor.Components.Common

<div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="card-body p-0">
        @if (IsLoading)
        {
            <div class="d-flex flex-column align-items-center justify-content-center py-5">
                <div class="spinner-border text-primary mb-3" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <span class="text-secondary">Fetching inventories...</span>
            </div>
        }
        else if (Inventories == null || !Inventories.Any())
        {
            <div class="text-center py-5">
                <div class="mb-3 text-muted">
                    <i class="bi bi-box-seam display-3"></i>
                </div>
                <h5 class="fw-semibold text-dark">No inventory found</h5>
                <p class="text-muted px-4">There are no batches registered matching your current filters.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">ID</th>
                            <th>Medicine</th>
                            <th>Batch Number</th>
                            <th class="text-center">Quantity</th>
                            <th>Expiry Date</th>
                            <th>Location</th>
                            <th class="pe-4 text-center">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var inv in Inventories)
                        {
                            var daysRemaining = (inv.ExpiryDate - DateTime.Today).TotalDays;
                            <tr>
                                <td class="ps-4">
                                    <a href="/inventory/@inv.InventoryId" class="badge bg-secondary-subtle text-secondary-emphasis font-monospace px-2 py-1 fs-7 text-decoration-none">#@inv.InventoryId</a>
                                </td>
                                <td>
                                    <a href="/medicines/@inv.MedicineId" class="fw-bold text-primary text-decoration-none">@inv.MedicineName</a>
                                </td>
                                <td>
                                    <span class="badge bg-light text-dark font-monospace border px-2 py-1">@inv.BatchNumber</span>
                                </td>
                                <td class="text-center">
                                    <span class="fw-bold text-primary">@inv.Quantity</span>
                                </td>
                                <td>
                                    <div class="d-flex flex-column">
                                        <span class="text-dark small">@inv.ExpiryDate.ToString("yyyy-MM-dd")</span>
                                        <span class="text-muted extra-small">Remaining: @((int)daysRemaining) days</span>
                                    </div>
                                </td>
                                <td>
                                    <span class="text-secondary small"><i class="bi bi-geo-alt me-1"></i>@(inv.Location ?? "Main Shelf")</span>
                                </td>
                                <td class="pe-4 text-center">
                                    @if (daysRemaining < 0)
                                    {
                                        <span class="badge bg-danger px-2 py-1 rounded-pill">Expired</span>
                                    }
                                    else if (daysRemaining <= 30)
                                    {
                                        <span class="badge bg-warning px-2 py-1 rounded-pill text-dark">Expiring Soon</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success px-2 py-1 rounded-pill">Fresh</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <PaginationControl TotalCount="TotalCount" Skip="Skip" PageSize="Take" OnPageChanged="OnPageChanged" />
        }
    </div>
</div>

@code {
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public List<InventoryDto>? Inventories { get; set; }
    [Parameter] public int TotalCount { get; set; }
    [Parameter] public int Skip { get; set; }
    [Parameter] public int Take { get; set; }
    [Parameter] public EventCallback<(int Skip, int Take)> OnPageChanged { get; set; }
}
