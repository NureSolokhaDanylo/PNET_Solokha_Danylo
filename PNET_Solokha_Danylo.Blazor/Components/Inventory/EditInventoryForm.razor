@using MediatR
@using PNET_Solokha_Danylo.Application.Inventories.Commands.UpdateInventory

<div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-header bg-white border-0 pt-4 px-4 pb-2">
        <h5 class="fw-bold mb-0 text-dark"><i class="bi bi-pencil-fill text-primary me-2"></i>Edit Inventory Batch</h5>
    </div>
    <div class="card-body px-4 pb-4">
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger alert-dismissible fade show rounded-3 mb-3" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i> @errorMessage
                <button type="button" class="btn-close" @onclick="() => errorMessage = null" aria-label="Close"></button>
            </div>
        }

        <EditForm Model="command" OnValidSubmit="HandleSubmit" FormName="EditInventoryFormInline">
            <FluentValidationValidator />
            
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label text-secondary small fw-medium">Batch Number</label>
                    <InputText @bind-Value="command.BatchNumber" class="form-control rounded-3" placeholder="e.g. BT-908A" />
                    <ValidationMessage For="@(() => command.BatchNumber)" class="text-danger small mt-1" />
                </div>

                <div class="col-md-6">
                    <label class="form-label text-secondary small fw-medium">Quantity</label>
                    <InputNumber @bind-Value="command.Quantity" class="form-control rounded-3" TValue="int" />
                    <ValidationMessage For="@(() => command.Quantity)" class="text-danger small mt-1" />
                </div>

                <div class="col-md-6">
                    <label class="form-label text-secondary small fw-medium">Expiry Date</label>
                    <InputDate @bind-Value="command.ExpiryDate" class="form-control rounded-3" />
                    <ValidationMessage For="@(() => command.ExpiryDate)" class="text-danger small mt-1" />
                </div>

                <div class="col-md-6">
                    <label class="form-label text-secondary small fw-medium">Location</label>
                    <InputText @bind-Value="command.Location" class="form-control rounded-3" placeholder="e.g. Main Shelf, Fridge" />
                    <ValidationMessage For="@(() => command.Location)" class="text-danger small mt-1" />
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary rounded-3 px-4" disabled="@isSaving">
                    @if (isSaving)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                    }
                    else
                    {
                        <i class="bi bi-save me-1"></i>
                    }
                    Save Changes
                </button>
                <button type="button" class="btn btn-outline-secondary rounded-3" @onclick="OnCancel" disabled="@isSaving">
                    <i class="bi bi-x-lg me-1"></i> Cancel
                </button>
            </div>
        </EditForm>
    </div>
</div>

@code {
    [Parameter] public int InventoryId { get; set; }
    [Parameter] public string InitialBatchNumber { get; set; } = string.Empty;
    [Parameter] public DateTime InitialExpiryDate { get; set; }
    [Parameter] public int InitialQuantity { get; set; }
    [Parameter] public string? InitialLocation { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    [Inject] private IMediator Mediator { get; set; } = default!;
    [Inject] private ILogger<EditInventoryForm> Logger { get; set; } = default!;

    private UpdateInventoryCommand command = new();
    private bool isSaving = false;
    private string? errorMessage;

    protected override void OnParametersSet()
    {
        command.InventoryId = InventoryId;
        command.BatchNumber = InitialBatchNumber;
        command.ExpiryDate = InitialExpiryDate;
        command.Quantity = InitialQuantity;
        command.Location = InitialLocation;
    }

    private async Task HandleSubmit()
    {
        isSaving = true;
        errorMessage = null;

        try
        {
            await Mediator.Send(command);
            Logger.LogInformation("Inventory item {InventoryId} updated successfully via component.", InventoryId);
            await OnSaved.InvokeAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error updating inventory item {InventoryId} in component.", InventoryId);
            errorMessage = ex.Message;
        }
        finally
        {
            isSaving = false;
        }
    }
}
